# Database (Neon Postgres — pooled connection for the app runtime)
DATABASE_URL="postgresql://user:password@localhost:5432/booking_platform?schema=public"
# Neon direct/unpooled connection, used by Prisma Migrate (bypasses PgBouncer).
# Locally this can be identical to DATABASE_URL; on Neon it's the non "-pooler" host.
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/booking_platform?schema=public"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Cloudinary (Phase 3 — listing image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# Stripe (test mode — Phase 11 for full payment flows, wired early for Phase 3 dev-env parity)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
